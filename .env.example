# Домен (обязательно для production с HTTPS)
DOMAIN=example.com

# Postgres
POSTGRES_USER=pet
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pet_db

# API
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://pet:change-me-strong-password@db:5432/pet_db
DB_HOST=db
DB_PORT=5432
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production

# DB на localhost сервера (для pgAdmin через SSH-туннель: ssh -L 5433:127.0.0.1:5432 user@server)
DB_PORT=5432
