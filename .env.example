# Домен (обязательно для production с HTTPS)
DOMAIN=example.com

# Postgres
POSTGRES_USER=pet
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pet_db

# API
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://pet:change-me-strong-password@db:5432/pet_db
DB_HOST=db
DB_PORT=5432
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production

# DB на localhost сервера (для pgAdmin через SSH-туннель: ssh -L 5433:127.0.0.1:5432 user@server)
DB_PORT=5432

# RuSender (транзакционные письма)
RUSENDER_API_KEY=rs_ck_v1_placeholder
RUSENDER_KEY_ID=0
RUSENDER_FROM_EMAIL=noreply@example.com
RUSENDER_FROM_NAME=Домашняя карта желаний
RUSENDER_API_BASE=https://api.rusender.ru/api/v1/external-mails/send
PUBLIC_APP_URL=http://localhost:8080
RESET_TOKEN_TTL_MIN=60
