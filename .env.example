# Postgres
POSTGRES_USER=pet
POSTGRES_PASSWORD=pet
POSTGRES_DB=pet_db

# API
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://pet:pet@db:5432/pet_db
DB_HOST=db
DB_PORT=5432
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production

# Published ports (host) — DB на хосте (pgAdmin); внутри Docker postgres на 5432
WEB_PORT=8080
API_PORT=3000
DB_PORT=5433
