# Application
NODE_ENV=development
PORT=3000

# Database (Docker: host is "db", local without Docker: "localhost")
DATABASE_URL=postgresql://pet:pet@localhost:5432/pet_db
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=debug
SWAGGER_ENABLED=true

# RuSender (транзакционные письма)
RUSENDER_API_KEY=rs_ck_v1_placeholder
RUSENDER_KEY_ID=0
RUSENDER_FROM_EMAIL=noreply@example.com
RUSENDER_FROM_NAME=Домашняя карта желаний
RUSENDER_API_BASE=https://api.rusender.ru/api/v1/external-mails/send
DOMAIN=localhost
PUBLIC_APP_URL=http://localhost:8080
RESET_TOKEN_TTL_MIN=60
