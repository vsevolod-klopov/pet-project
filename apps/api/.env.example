# Application
NODE_ENV=development
PORT=3000

# Database (Docker: host is "db", local without Docker: "localhost")
DATABASE_URL=postgresql://pet:pet@localhost:5432/pet_db
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=debug
SWAGGER_ENABLED=true
